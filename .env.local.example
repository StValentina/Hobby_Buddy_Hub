# Environment Variables Template for Hobby Buddy Hub

# ============================================================================
# Supabase Configuration
# ============================================================================

# Your Supabase project URL (from Supabase dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public API key (safe to expose in frontend)
VITE_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase service role key (KEEP SECRET - for migrations/backend only)
# Get this from: Supabase Dashboard > Project Settings > API Keys > Service Role
# ⚠️  NEVER commit this to version control or expose in frontend!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# Optional: Development Settings
# ============================================================================

# Database environment (development, staging, production)
# DB_ENV=development

# Enable verbose logging for migrations
# DEBUG_MIGRATIONS=true
